# --- Pipeline (regenerável, pesado) ---
.cache/
cache/

# --- Pacotes para jogador (vão no GitHub Release, não no git) ---
releases/
pack/

# --- BepInEx zip (~31 MB) — baixar com: make fetch-bepinex-vendor ---
vendor/BepInExPack_IL2CPP.zip
vendor/Translator/Translator.dll

# --- Plugin C# (build local) ---
bepinex-plugin/**/bin/
bepinex-plugin/**/obj/
bepinex-plugin/**/*.dll
bepinex-plugin/**/*.pdb

# --- dist/ — versionado: PgTranslateLive.dll, Translator.dll, *.cfg ---
# Gerados localmente (PyInstaller), não commitar:
dist/PgPtBr-Installer
dist/INSTALAR.exe
dist/INSTALAR.pdb
dist/DESINSTALAR.exe
dist/uninstall-language-pack-ptbr.exe
dist/*.pdb

# --- Instaladores Windows (PyInstaller) ---
# Gerar com: powershell -File scripts/build-windows-installer.ps1
build/installer/
installer/build/
installer/dist/
installer/game-uninstall/*.exe

# --- Desinstalador legado (substituído por game-uninstall/uninstall-language-pack-ptbr) ---
installer/DESINSTALAR

# --- Inspeção / testes locais (extrair zip, validar BepInEx, etc.) ---
.tmp-*/

# --- Logs do jogo/Steam (podem ter caminhos locais) ---
Player.log
*.log
steam-*.log

# --- Segredos ---
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
build/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- VM / ISO (não pertencem ao repo) ---
*.iso
*.vdi
*.vmdk
*.vbox-*
scripts/Mido.sh

# --- IDE / OS ---
.idea/
.vscode/
.cursor/
*.swp
.DS_Store
Thumbs.db
desktop.ini

# NOTA: output/Translation/ e output/pt-BR/ são versionados (~35 MB) — ver README.
# NOTA: dist/PgTranslateLive.dll e dist/Translator.dll são versionados (plugins pré-compilados).
# NOTA: installer/game-uninstall/uninstall-language-pack-ptbr (bash) é versionado; o .exe é gerado no build.
