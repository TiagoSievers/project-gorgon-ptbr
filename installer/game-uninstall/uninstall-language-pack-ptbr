#!/usr/bin/env bash
# Desinstala mod PT-BR — executar de Project Gorgon/ (pasta do jogo)
set -euo pipefail

GAME_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")")" && pwd)"
SCRIPT_PATH="$GAME_DIR/uninstall-language-pack-ptbr"
UNITY_LINUX="${UNITY_LINUX:-$HOME/.config/unity3d/Elder Game/Project Gorgon}"

die_gui() {
  zenity --error --width=440 --title="Project Gorgon PT-BR" --text="$1" 2>/dev/null || {
    echo "Erro: $1" >&2
    read -r -p "Enter para sair…"
  }
  exit 1
}

need_zenity() {
  command -v zenity >/dev/null 2>&1 || die_gui "Instale zenity:\n  sudo apt install zenity"
}

remove_path() {
  local path="$1"
  local label="$2"
  if [[ -e "$path" ]]; then
    rm -rf "$path"
    echo "  OK   removido: $label"
  else
    echo "  OK   ja ausente: $label"
  fi
}

proton_prefix() {
  local app_id="$1"
  local steam_root=""
  for candidate in \
    "$HOME/.steam/debian-installation" \
    "$HOME/.steam/steam" \
    "$HOME/.local/share/Steam" \
    "$HOME/.var/app/com.valvesoftware.Steam/.local/share/Steam"; do
    if [[ -d "$candidate/steamapps" ]]; then
      steam_root="$candidate"
      break
    fi
  done
  [[ -n "$steam_root" ]] || return 0
  echo "$steam_root/steamapps/compatdata/$app_id/pfx/drive_c/users/steamuser/AppData/LocalLow/Elder Game/Project Gorgon/Translation"
}

main() {
  need_zenity

  zenity --question --width=520 --title="Project Gorgon PT-BR — Desinstalar" \
    --text="Remover traducao PT-BR deste computador?\n\nSerao apagados:\n• BepInEx, dotnet, winhttp.dll\n• Plugins e language pack PT-BR\n\nO jogo voltara ao ingles.\n\nContinuar?" \
    || exit 0

  echo "Desinstalando mod PT-BR..."
  echo "Jogo: $GAME_DIR"

  remove_path "$GAME_DIR/BepInEx/DESINSTALAR.exe" "Desinstalador legado (BepInEx)"
  remove_path "$GAME_DIR/BepInEx" "BepInEx"
  remove_path "$GAME_DIR/dotnet" "dotnet"
  remove_path "$GAME_DIR/winhttp.dll" "winhttp.dll"
  remove_path "$GAME_DIR/doorstop_config.ini" "doorstop_config.ini"
  remove_path "$GAME_DIR/.doorstop_version" ".doorstop_version"
  remove_path "$UNITY_LINUX/Translation" "Language pack Linux"
  for app in 342940 969170; do
    prefix="$(proton_prefix "$app")"
    [[ -n "$prefix" ]] && remove_path "$prefix" "Language pack Proton $app"
  done

  zenity --info --width=480 --title="Desinstalacao concluida" \
    --text="Mod PT-BR removido.\n\nO jogo voltou ao ingles.\nAbra pela Steam normalmente."

  (sleep 1; rm -f "$SCRIPT_PATH") &
}

main "$@"
